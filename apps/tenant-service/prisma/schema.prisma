// This is your Prisma schema file for tenant-service

generator client {
  provider      = "prisma-client-js"
  output        = "../src/prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(100)    // subdomain: {slug}.yourplatform.com
  plan          String    @default("free") @db.VarChar(20)
  status        String    @default("trial") @db.VarChar(20) // trial|active|suspended|cancelled
  trialEndsAt   DateTime? @map("trial_ends_at") @db.Timestamptz
  billingEmail  String    @map("billing_email") @db.Text    // AES-256 encrypted
  billingName   String?   @map("billing_name") @db.VarChar(255)
  billingAddress Json?    @map("billing_address")
  timezone      String    @default("UTC") @db.VarChar(60)
  locale        String    @default("en-IN") @db.VarChar(10)
  currency      String    @default("INR") @db.VarChar(3)
  customDomain  String?   @map("custom_domain") @db.Text
  logoUrl       String?   @map("logo_url") @db.Text
  settings      Json      @default("{}")
  dbSchemaName  String?   @map("db_schema_name") @db.VarChar(63)  // enterprise: separate PG schema
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  featureFlags TenantFeatureFlag[]

  @@map("tenants")
}

model TenantPlan {
  id                  String  @id @default(uuid())
  name                String  @unique @db.VarChar(50)  // free|starter|pro|enterprise
  priceMonthly        Int     @map("price_monthly_cents")        // in paise
  priceAnnual         Int     @map("price_annual_cents")
  maxProducts         Int     @default(100) @map("max_products")
  maxOrdersPerMonth   Int     @default(500) @map("max_orders_per_month")
  maxStaffUsers       Int     @default(2) @map("max_staff_users")
  maxWarehouses       Int     @default(1) @map("max_warehouses")
  features            Json    @default("{}")
  isActive            Boolean @default(true) @map("is_active")

  @@map("tenant_plans")
}

model TenantFeatureFlag {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  flagKey   String    @map("flag_key") @db.VarChar(100)
  isEnabled Boolean   @default(false) @map("is_enabled")
  config    Json?
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flagKey])
  @@map("tenant_feature_flags")
}

model TenantUsageLog {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  month             String    @db.VarChar(7)   // YYYY-MM
  productCount      Int       @default(0) @map("product_count")
  orderCount        Int       @default(0) @map("order_count")
  staffCount        Int       @default(0) @map("staff_count")
  warehouseCount    Int       @default(0) @map("warehouse_count")
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, month])
  @@map("tenant_usage_logs")
}
