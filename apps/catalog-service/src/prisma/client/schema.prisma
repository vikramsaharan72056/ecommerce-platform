// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  parentId    String? @map("parent_id") @db.Uuid
  name        String  @db.VarChar(255)
  slug        String  @db.VarChar(255)
  description String? @db.Text
  imageUrl    String? @map("image_url") @db.Text
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  // Nested Set Model fields
  lft   Int?
  rgt   Int?
  depth Int?

  metaTitle String?  @map("meta_title") @db.VarChar(160)
  metaDesc  String?  @map("meta_desc") @db.VarChar(320)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
}

model Attribute {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  name         String  @db.VarChar(100)
  slug         String  @db.VarChar(100)
  type         String  @db.VarChar(20) // text|number|boolean|select|multi_select|color
  unit         String? @db.VarChar(20)
  isFilterable Boolean @default(false) @map("is_filterable")
  isSearchable Boolean @default(false) @map("is_searchable")
  isRequired   Boolean @default(false) @map("is_required")
  options      Json? // For select/multi_select types

  @@unique([tenantId, slug])
  @@map("attributes")
}

model Product {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  sellerId    String    @map("seller_id") @db.Uuid
  categoryId  String    @map("category_id") @db.Uuid
  brandId     String?   @map("brand_id") @db.Uuid
  name        String    @db.VarChar(500)
  slug        String    @db.VarChar(500)
  description String?   @db.Text
  shortDesc   String?   @map("short_desc") @db.Text
  sku         String?   @db.VarChar(100)
  barcode     String?   @db.VarChar(100)
  status      String    @default("draft") @db.VarChar(20) // draft|active|inactive|rejected
  type        String    @default("simple") @db.VarChar(20) // simple|variable|bundle|digital
  isFeatured  Boolean   @default(false) @map("is_featured")
  tags        String[]
  attributes  Json      @default("{}")
  metaTitle   String?   @map("meta_title") @db.VarChar(160)
  metaDesc    String?   @map("meta_desc") @db.VarChar(320)
  weightGrams Int?      @map("weight_grams")
  dimensions  Json? // { length, width, height, unit }
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  media    ProductMedia[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("products")
}

model ProductVariant {
  id                  String  @id @default(uuid()) @db.Uuid
  productId           String  @map("product_id") @db.Uuid
  tenantId            String  @map("tenant_id") @db.Uuid
  sku                 String  @db.VarChar(100)
  name                String? @db.VarChar(255)
  attributes          Json    @default("{}")
  mrpCents            BigInt  @map("mrp_cents")
  sellingPriceCents   BigInt  @map("selling_price_cents")
  costPriceCents      BigInt? @map("cost_price_cents")
  compareAtPriceCents BigInt? @map("compare_at_price_cents")
  barcode             String? @db.VarChar(100)
  weightGrams         Int?    @map("weight_grams")
  isActive            Boolean @default(true) @map("is_active")
  sortOrder           Int     @default(0) @map("sort_order")

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   ProductMedia[]

  @@unique([tenantId, sku])
  @@map("product_variants")
}

model ProductMedia {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  type      String  @db.VarChar(20) // image|video|360
  url       String  @db.Text
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("product_media")
}
