// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  email          String    @db.VarChar(320)
  passwordHash   String?   @map("password_hash") @db.Text
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  phone          String?   @db.Text       // AES-256 encrypted
  role           String    @default("customer") @db.VarChar(20)  // owner|admin|staff|customer
  status         String    @default("pending") @db.VarChar(20)   // pending|active|suspended|deleted
  isVerified     Boolean   @default(false) @map("is_verified")
  isMfaEnabled   Boolean   @default(false) @map("is_mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") @db.Text          // AES-256 encrypted TOTP secret
  avatarUrl      String?   @map("avatar_url") @db.Text
  failedLogins   Int       @default(0) @map("failed_logins")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  refreshTokens       RefreshToken[]
  verificationTokens  VerificationToken[]
  oauthProviders      OAuthProvider[]
  mfaBackupCodes      MfaBackupCode[]

  @@unique([tenantId, email])
  @@index([tenantId, email], name: "idx_users_tenant_email")
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tenantId    String    @map("tenant_id")
  tokenHash   String    @unique @map("token_hash") @db.Text  // SHA-256 of actual token
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

model VerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash") @db.Text
  type        String    @db.VarChar(30)   // email_verify|password_reset
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model OAuthProvider {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  provider        String    @db.VarChar(30)   // google|facebook|apple|github
  providerUserId  String    @map("provider_user_id") @db.Text
  accessTokenEnc  String?   @map("access_token_enc") @db.Text   // AES-256 encrypted
  refreshTokenEnc String?   @map("refresh_token_enc") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_providers")
}

model MfaBackupCode {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  codeHash    String    @map("code_hash") @db.Text   // bcrypt hash
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_backup_codes")
}
